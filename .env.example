# ResearchToolsPy — Environment Variables
#
# Copy to .env for local dev. For production, set these as Cloudflare Pages
# secrets (`wrangler pages secret put NAME --project-name researchtoolspy`).
#
# This file lists only secrets and runtime configuration. Cloudflare bindings
# (DB, SESSIONS, CACHE, AI_CONFIG, UPLOADS, ASSETS, RATE_LIMIT) are declared
# in wrangler.toml and do NOT belong here.
#
# Local-CLI-only:
#   RESEARCHTOOLS_USER_HASH — used by scripts/cop-api.sh for `cop_*` shell
#   functions. Min 16 chars; gets you a guest workspace.
RESEARCHTOOLS_USER_HASH=

# ── AI / OpenAI ────────────────────────────────────────────────────────────
# Required for AI features (entity extraction, synthesis, Q&A generation).
# Calls are proxied through Cloudflare AI Gateway when AI_GATEWAY_ACCOUNT_ID
# is set, which gives you caching + observability.
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
AI_GATEWAY_ACCOUNT_ID=
DEFAULT_AI_MODEL=gpt-5.4-mini
ENABLE_AI_FEATURES=true

# ── External data sources ──────────────────────────────────────────────────
# All optional — feature toggles when missing.
ACLED_API_KEY=
ACLED_EMAIL=
APIFY_API_KEY=
PDF_CO_API_KEY=
REDSIGHT_API_KEY=
REDSIGHT_API_URL=
GITHUB_TOKEN=

# ── Containerized helpers (containers/) ────────────────────────────────────
# URLs of the OSINT agent and SearXNG meta-search if you're running them.
OSINT_AGENT_URL=
SEARXNG_CONTAINER_URL=

# ── Auth ───────────────────────────────────────────────────────────────────
# JWT secret used to sign session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# Hash representing the "system" user that owns automated submissions.
SYSTEM_USER_HASH=

# Bot intake endpoint shared secret (behavior framework bot → /api/public/intake).
BOT_INTAKE_API_KEY=

# ── OIDC (optional — only if wiring an external IdP) ───────────────────────
OIDC_AUTHORIZATION_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
