        "0": { "label": "N/A", "description": "No past deceptions" },
        "1": { "label": "Crude", "description": "Simple lies, easily detected" },
        "2": { "label": "Basic", "description": "Some planning, moderate success" },
        "3": { "label": "Skillful", "description": "Well-planned, multi-layered" },
        "4": { "label": "Advanced", "description": "Highly sophisticated operations" },
        "5": { "label": "Masterful", "description": "State-of-the-art tradecraft" }
      }
    },
    "successRate": {
      "label": "Past Deception Success",
      "description": "How often did past deceptions succeed?",
