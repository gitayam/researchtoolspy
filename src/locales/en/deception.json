        "1": { "label": "Rarely", "description": "1-2 incidents over many years" },
        "2": { "label": "Occasionally", "description": "Several documented cases" },
        "3": { "label": "Frequently", "description": "Regular pattern established" },
        "4": { "label": "Routinely", "description": "Standard operating procedure" },
        "5": { "label": "Systematically", "description": "Core doctrine/strategy" }
      }
    },
    "sophisticationLevel": {
      "label": "Deception Sophistication",
      "description": "How complex were past deceptions?",
